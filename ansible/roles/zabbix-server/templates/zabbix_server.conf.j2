# Zabbix Server Configuration File
LogFile=/var/log/zabbix/zabbix_server.log
LogFileSize=50
PidFile=/var/run/zabbix/zabbix_server.pid
SocketDir=/var/run/zabbix
DBHost={{ db_host }}
DBName={{ db_name }}
DBUser={{ db_user }}
DBPassword={{ db_password }}
DBPort={{ mysql_port | default(3306) }}

# Cache size parameters tuned for enterprise workloads
CacheSize={{ zbx_cachesize }}
HistoryCacheSize={{ zbx_historycachesize }}
TrendCacheSize={{ zbx_trendcachesize }}
ValueCacheSize={{ zbx_valuecachesize }}

# Process pollers
StartPollers={{ zbx_startpollers }}
StartPollersUnreachable=5
StartTrappers=5
StartPingers=5
StartDiscoverers=3
StartHTTPPollers=3
StartHistoryPollers=5
StartPreprocessors=6

Timeout=10
AlertScriptsPath=/usr/lib/zabbix/alertscripts
ExternalScripts=/usr/lib/zabbix/externalscripts
FpingLocation=/usr/bin/fping
LogSlowQueries=3000

# SNMP trap support
StartSNMPTrapper=1
SNMPTrapperFile=/var/lib/zabbix/snmptraps/snmptraps.log
