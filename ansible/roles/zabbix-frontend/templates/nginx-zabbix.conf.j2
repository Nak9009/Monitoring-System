server {
    listen 80;
    server_name zabbix.internal;

    # Redirect all HTTP requests to HTTPS (production best practice)
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name zabbix.internal;

    # SSL Certs
    ssl_certificate /etc/ssl/certs/monitoring/server.crt;
    ssl_certificate_key /etc/ssl/certs/monitoring/server.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    root /usr/share/zabbix;
    index index.php;

    # Security Headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Content-Security-Policy "default-src 'self' 'unsafe-inline' 'unsafe-eval' data:; frame-ancestors 'self';" always;

    location / {
        try_files $uri $uri/ =404;
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/var/run/php/php-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
    }

    location ~ /\.ht {
        deny all;
    }
}
