[mysqld]
# -----------------------------------------------------------------------------
# Fine Tuning & Memory Management (Tuned for 4GB RAM Host)
# -----------------------------------------------------------------------------
port                    = {{ mysql_port }}
bind-address            = 0.0.0.0

key_buffer_size         = 16M
max_allowed_packet      = 64M
thread_stack            = 256K
thread_cache_size       = 32

max_connections         = {{ mysql_max_connections }}
max_user_connections    = 100

tmp_table_size          = 32M
max_heap_table_size     = 32M

# InnoDB settings
innodb_buffer_pool_size         = {{ mysql_buffer_pool_size }}
innodb_buffer_pool_instances    = {{ mysql_buffer_pool_instances }}
innodb_log_file_size            = {{ mysql_log_file_size }}
innodb_log_buffer_size          = {{ mysql_log_buffer_size }}
innodb_file_per_table           = 1
innodb_flush_log_at_trx_commit  = 2
innodb_flush_method             = O_DIRECT

# -----------------------------------------------------------------------------
# Replication Settings (HA Setup)
# -----------------------------------------------------------------------------
server-id                       = {{ mysql_server_id }}
log_bin                         = /var/log/mysql/mysql-bin.log
binlog_format                   = ROW
binlog_expire_logs_seconds      = 259200
max_binlog_size                 = 100M
relay-log                       = /var/log/mysql/mysql-relay-bin.log
read_only                       = {{ mysql_read_only }}
log_bin_trust_function_creators = 1

# Skip DNS resolution
skip-name-resolve

# UTF-8
character-set-server            = utf8mb4
collation-server                = utf8mb4_unicode_ci
