[mysqld]
# -----------------------------------------------------------------------------
# Connection / Thread Settings
# -----------------------------------------------------------------------------
user            = mysql
pid-file        = /var/run/mysqld/mysqld.pid
socket          = /var/run/mysqld/mysqld.sock
port            = 3306
datadir         = /var/lib/mysql
secure-file-priv= NULL

# Security / Network
bind-address   = 0.0.0.0
mysqlx          = OFF

# -----------------------------------------------------------------------------
# Fine Tuning & Memory Management (Tuned for 4GB RAM Host)
# -----------------------------------------------------------------------------
key_buffer_size         = 16M
max_allowed_packet      = 64M
thread_stack            = 256K
thread_cache_size       = 32

# Connections limit
max_connections        = 150
max_user_connections   = 100

# Cache sizes
tmp_table_size          = 32M
max_heap_table_size     = 32M

# -----------------------------------------------------------------------------
# InnoDB Settings (Zabbix Tuning)
# -----------------------------------------------------------------------------
# Buffer pool: 25-30% of total host RAM (1 GB is safe for 4 GB RAM VM node)
innodb_buffer_pool_size         = 1G
innodb_buffer_pool_instances    = 1
innodb_log_file_size            = 256M
innodb_log_buffer_size          = 16M
innodb_file_per_table           = 1

# Performance optimization: 2 allows OS-caching before flushing (faster writes)
# If ACID durability is strictly required, change to 1.
innodb_flush_log_at_trx_commit  = 2
innodb_flush_method             = O_DIRECT
innodb_doublewrite              = 1

# -----------------------------------------------------------------------------
# Logging and Replication (Required for HA / Replication Setup)
# -----------------------------------------------------------------------------
# Enable binary logging for replication
server-id                       = 1
log-bin                         = mysql-bin
binlog_format                   = ROW
binlog_expire_logs_seconds      = 259200 # 3 days retention to save disk space
max_binlog_size                 = 100M
log_bin_trust_function_creators = 1

# Disable DNS resolution to speed up connections
skip-name-resolve

# Character set / Collation
character-set-server            = utf8mb4
collation-server                = utf8mb4_unicode_ci
