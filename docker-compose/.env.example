# =============================================================================
# Monitoring Stack Environment Variables
# =============================================================================
# Copy this file to .env and customize values before deploying.
#   cp .env.example .env
#
# SECURITY: Never commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
# Compose project name — used as prefix for containers, volumes, networks
COMPOSE_PROJECT_NAME=monitoring

# Timezone applied to all containers (IANA format)
TZ=Asia/Phnom_Penh

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DB_NAME=zabbix
DB_USER=zabbix
DB_PASSWORD=CHANGE_ME_zabbix_db_password
DB_ROOT_PASSWORD=CHANGE_ME_mysql_root_password
DB_PORT=3306

# -----------------------------------------------------------------------------
# Zabbix Server
# -----------------------------------------------------------------------------
ZABBIX_SERVER_IMAGE=zabbix/zabbix-server-mysql:ubuntu-7.0-latest

# Cache sizes (bytes). Reduced for 4GB system.
ZBX_CACHESIZE=128M
ZBX_HISTORYCACHESIZE=64M
ZBX_HISTORYINDEXCACHESIZE=16M
ZBX_TRENDCACHESIZE=32M
ZBX_TRENDFUNCTIONCACHESIZE=32M
ZBX_VALUECACHESIZE=64M

# Poller processes — scale with number of monitored hosts
ZBX_STARTPOLLERS=20
ZBX_STARTPOLLERSUNREACHABLE=5
ZBX_STARTTRAPPERS=10
ZBX_STARTPINGERS=5
ZBX_STARTDISCOVERERS=5
ZBX_STARTHTTPPOLLERS=5

# Housekeeping — how long to retain data (days)
ZBX_HOUSEKEEPINGFREQUENCY=1
ZBX_MAXHOUSEKEEPERDELETE=50000

# Timeout for checks (seconds, max 30)
ZBX_TIMEOUT=15

# SNMP community string for auto-discovery
ZBX_SNMP_COMMUNITY=public

# -----------------------------------------------------------------------------
# Zabbix Web Frontend (Nginx)
# -----------------------------------------------------------------------------
ZABBIX_WEB_IMAGE=zabbix/zabbix-web-nginx-mysql:ubuntu-7.0-latest

# PHP settings
ZBX_SERVER_NAME=Monitoring Stack
PHP_TZ=${TZ}
ZBX_MAXEXECUTIONTIME=600
ZBX_MEMORYLIMIT=256M
ZBX_POSTMAXSIZE=32M
ZBX_UPLOADMAXFILESIZE=16M

# -----------------------------------------------------------------------------
# Zabbix Agent 2 (self-monitoring)
# -----------------------------------------------------------------------------
ZABBIX_AGENT_IMAGE=zabbix/zabbix-agent2:7.0-alpine-latest
ZBX_HOSTNAME=monitoring-host
ZBX_SERVER_HOST=zabbix-server
ZBX_ACTIVE_ALLOW=zabbix-server

# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------
GRAFANA_IMAGE=grafana/grafana-oss:11.6.0

# Admin credentials — change immediately after first login
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_grafana_admin_password

# Grafana server settings
GF_SERVER_ROOT_URL=http://localhost:3000
GF_SERVER_DOMAIN=localhost

# SMTP for alerting (optional)
GF_SMTP_ENABLED=false
GF_SMTP_HOST=smtp.example.com:587
GF_SMTP_USER=alerts@example.com
GF_SMTP_PASSWORD=CHANGE_ME_smtp_password
GF_SMTP_FROM_ADDRESS=alerts@example.com
GF_SMTP_FROM_NAME=Grafana Alerts

# Grafana plugins to install at startup
GF_INSTALL_PLUGINS=alexanderzobnin-zabbix-app

# -----------------------------------------------------------------------------
# Loki (Log Aggregation)
# -----------------------------------------------------------------------------
LOKI_IMAGE=grafana/loki:3.5.0

# Retention period for logs (hours). 720h = 30 days
LOKI_RETENTION_PERIOD=720h

# -----------------------------------------------------------------------------
# Promtail (Log Shipper)
# -----------------------------------------------------------------------------
PROMTAIL_IMAGE=grafana/promtail:3.5.0

# -----------------------------------------------------------------------------
# Uptime Kuma
# -----------------------------------------------------------------------------
UPTIME_KUMA_IMAGE=louislam/uptime-kuma:1

# -----------------------------------------------------------------------------
# Networking
# -----------------------------------------------------------------------------
# Exposed ports on the Docker host
ZABBIX_WEB_HTTP_PORT=8080
ZABBIX_WEB_HTTPS_PORT=8443
GRAFANA_PORT=3000
UPTIME_KUMA_PORT=3001
LOKI_PORT=3100

# Zabbix server trapper port (agents send data here)
ZABBIX_SERVER_PORT=10051

# -----------------------------------------------------------------------------
# TLS / HTTPS (optional — mount certs into nginx container)
# -----------------------------------------------------------------------------
# Path to TLS certificate and key on the Docker host
TLS_CERT_PATH=./certs/server.crt
TLS_KEY_PATH=./certs/server.key

# -----------------------------------------------------------------------------
# Backup
# -----------------------------------------------------------------------------
BACKUP_DIR=/opt/backups/monitoring
BACKUP_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# Telegram Alerting (optional)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
